<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d0d0d">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!--
        Right-edge tab. The inner TextView is 120dp × 30dp and rotated -90°,
        so it appears 30dp wide and ~120dp tall — fitting neatly inside the
        30dp × 140dp container that floats over the right edge.
    -->
    <LinearLayout
        android:id="@+id/tabAppUsage"
        android:layout_width="30dp"
        android:layout_height="140dp"
        android:layout_gravity="center_vertical|end"
        android:background="@drawable/tab_bg"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="120dp"
            android:layout_height="30dp"
            android:gravity="center"
            android:letterSpacing="0.08"
            android:rotation="-90"
            android:text="app usage today"
            android:textColor="#888888"
            android:textSize="10sp" />
    </LinearLayout>

</FrameLayout>
