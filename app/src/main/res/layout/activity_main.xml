<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#0d0d0d">

    <TextView
        android:id="@+id/tvBalance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⬡ 5.0 coins remaining"
        android:textColor="#c8f542"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DeAlgofy"
        android:textColor="#e8e8e8"
        android:textSize="14sp"
        android:letterSpacing="0.2"
        android:layout_marginBottom="64dp"/>

    <Button
        android:id="@+id/btnRequestPermission"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Grant Usage Access"
        android:backgroundTint="#1c1c1c"
        android:textColor="#999999"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnRequestOverlay"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Grant Overlay Permission"
        android:backgroundTint="#1c1c1c"
        android:textColor="#999999"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnStartService"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Start DeAlgofy"
        android:backgroundTint="#c8f542"
        android:textColor="#000000"
        android:textStyle="bold"/>

</LinearLayout>