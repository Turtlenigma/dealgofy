<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.DeAlgofy" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">#c8f542</item>
        <item name="colorPrimaryVariant">#a0c030</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="colorSurface">#1c1c1c</item>
        <item name="colorOnSurface">#e8e8e8</item>
        <item name="android:windowBackground">#0d0d0d</item>
    </style>

    <!--
        Used by FocusBottomSheet.getTheme(). Transparent window so the sheet's
        own bottom_sheet_bg drawable (rounded dark card) is visible directly.
    -->
    <style name="DarkBottomSheetTheme" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="bottomSheetStyle">@style/DarkBottomSheetStyle</item>
    </style>

    <style name="DarkBottomSheetStyle" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

</resources>
